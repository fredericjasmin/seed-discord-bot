<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container mt-5">
    <h1 class="mb-4 text-center text-muted">Profile</h1>

    <% if (message) { %>
        <div class="alert alert-<%= messageType %>" role="alert">
            <%= message %>
        </div>
    <% } %>

    <div class="text-center mb-5">
        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=256" alt="User Avatar" class="rounded-circle border border-2 border-secondary p-1 mb-3" width="120" height="120">
        <h2 class="fw-bold mb-1"><%= user.username %></h2>
    <p class="text-secondary">Discord ID: <%= user.id %></p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg mb-4 border-0"> <!-- Stronger shadow, no border -->
                <div class="card-header bg-primary text-white py-3"> <!-- More padding -->
                    <h4 class="mb-0"><i class="bi bi-cash-coin me-2"></i>Economy Stats</h4>
                </div>
                <div class="card-body">
                    <div class="row text-center"> <!-- Centered text for stats -->
                        <div class="col-6 border-end"> <!-- Separator -->
                            <p class="fs-6 text-muted mb-1">Coins</p>
                            <p class="fs-3 text-success fw-bold"><%= userData.coins %></p>
                        </div>
                        <div class="col-6">
                            <p class="fs-6 text-muted mb-1">Bank</p>
                            <p class="fs-3 text-info fw-bold"><%= userData.bank %></p>
                        </div>
                    </div>
                </div>

                <div class="card-header bg-secondary text-white py-3 mt-3"> <!-- More padding, mt-3 for spacing -->
                    <h4 class="mb-0"><i class="bi bi-bag-fill me-2"></i>Inventory</h4>
                </div>
                <div class="card-body">
                    <% if (userData.inventory && userData.inventory.length > 0) { %>
                        <ul class="list-group list-group-flush">
                            <% userData.inventory.forEach(item => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center py-2 px-3 mb-2 rounded border shadow-sm"> <!-- Enhanced item styling -->
                                    <span class="fw-bold text-dark"><%= item %></span>
                                    <span class="badge bg-dark text-white rounded-pill px-3 py-2">x1</span>
                                </li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        <p class="text-muted text-center py-3">Your inventory is empty.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 text-center">
    <a href="/auth/logout" class="btn btn-outline-danger btn-lg px-4">Logout</a>
    </div>
</div>

<%- include('partials/footer') %>