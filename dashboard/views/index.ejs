<%- include('partials/header') %>
<%- include('partials/navbar') %>

<h1>Dashboard</h1>
<p class="text-muted">An overview of your bot's statistics.</p>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="stat-card">
            <h5 class="card-title">Servers</h5>
            <p class="card-text"><%= guilds %></p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <h5 class="card-title">Users</h5>
            <p class="card-text"><%= users %></p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <h5 class="card-title">Channels</h5>
            <p class="card-text"><%= channels %></p>
        </div>
    </div>
</div>

<div class="mt-4">
    <h2>Available Commands</h2>
    <% Object.keys(commands).sort().forEach(category => { %>
    <h4 class="mt-4 text-capitalize" style="color: var(--accent-color);"><%= category %></h4>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Command</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    <% commands[category].forEach(command => { %>
                        <tr>
                            <td><code>/<%= command.name %></code></td>
                            <td><%= command.description %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% }) %>
</div>

<%- include('partials/footer') %>