<%- include('partials/header') %>
<%- include('partials/navbar') %>

<h1>Economy Leaderboard</h1>
<p class="text-muted">The richest users in the bot, ranked by bank money.</p>

<div class="table-responsive mt-4">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>User</th>
                <th>Wallet</th>
                <th>Bank</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            <% leaderboard.forEach(user => { %>
                <tr>
                    <td><%= user.rank %></td>
                    <td class="d-flex align-items-center">
                        <% if (user.avatar) { %>
                            <img src="<%= user.avatar %>" alt="Avatar" width="50" height="50" style="border-radius: 50%; margin-right: 15px;">
                        <% } else { %>
                            <div style="width: 50px; height: 50px; background-color: #3a3d52; border-radius: 50%; margin-right: 15px; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                                <%= user.username ? user.username.charAt(0) : '-' %>
                            </div>
                        <% } %>
                        <span><%= user.username || '-' %></span>
                    </td>
                    <td><%= user.coins.toLocaleString() %> 🪙</td>
                    <td><%= user.bank.toLocaleString() %> 🏦</td>
                    <td><strong><%= (user.coins + user.bank).toLocaleString() %></strong></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<%- include('partials/footer') %>