<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container mt-5">
    <h1 class="mb-4 text-center">Shop</h1>

    <% if (message) { %>
        <div class="alert alert-<%= messageType === 'success' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
            <%= message %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>

    <% if (products && products.length > 0) { %>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% products.forEach(product => { %>
                <div class="col">
                    <div class="card h-100 shadow-sm product-card">
                        <img src="https://via.placeholder.com/150" class="card-img-top" alt="<%= product.name %> Placeholder Image">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-center"><%= product.name %></h5>
                            <p class="card-text flex-grow-1 text-muted"><%= product.description %></p>
                            <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                                <h6 class="mb-0"><strong>Price:</strong> <%= product.price.toLocaleString('en-US') %> Coins</h6>
                                <form action="/shop/buy" method="POST">
                                    <input type="hidden" name="productId" value="<%= product.id %>">
                                    <button type="submit" class="btn btn-primary btn-sm">Buy Now</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="alert alert-info text-center" role="alert">
            No items available in the shop yet. Check back later!
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>