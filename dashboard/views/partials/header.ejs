<!DOCTYPE html>
<html lang="en">

<head>
        <!-- Select2 CSS -->
        <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
        <style>
            /* Select2 dark theme override para dashboard */
            .select2-container--default .select2-selection--multiple {
                background-color: var(--surface-hover) !important;
                border: 1px solid rgba(255,255,255,0.1) !important;
                color: var(--text-color) !important;
                border-radius: var(--border-radius-sm) !important;
                min-height: 36px;
                padding: 2px 8px 2px 8px;
            }
            .select2-container--default .select2-selection--multiple .select2-selection__choice {
                background-color: var(--accent-color) !important;
                color: #fff !important;
                border: none !important;
                border-radius: 8px !important;
                font-size: 0.95em;
                margin: 2px 4px 2px 0;
                padding: 4px 10px 4px 24px;
                position: relative;
            }
            .select2-container--default .select2-selection--multiple .select2-selection__choice__remove {
                color: #fff !important;
                background: transparent !important;
                border: none !important;
                font-size: 1.2em;
                font-weight: bold;
                position: absolute;
                left: 6px;
                top: 2px;
                cursor: pointer;
                opacity: 0.8;
                transition: color 0.2s;
            }
            .select2-container--default .select2-selection--multiple .select2-selection__choice__remove:hover {
                color: var(--error-color) !important;
                opacity: 1;
            }
            .select2-container--default .select2-selection--multiple .select2-search__field {
                background: transparent !important;
                color: var(--text-color) !important;
            }
            .select2-dropdown {
                background-color: var(--surface-color) !important;
                color: var(--text-color) !important;
                border-radius: var(--border-radius-sm) !important;
                border: 1px solid var(--accent-color) !important;
            }
            .select2-results__option--highlighted {
                background-color: var(--accent-color) !important;
                color: #fff !important;
            }
            .select2-container--default .select2-selection--multiple .select2-selection__rendered {
                display: flex;
                flex-wrap: wrap;
                align-items: center;
                padding-bottom: 0 !important;
            }
        </style>
    <!-- Choices.js CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Seed Dashboard</title>
    <link rel="icon" href="/images/favicon.ico" type="image/x-icon">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        /* ===== Choices.js Custom Theme for Dashboard ===== */
        .choices {
            background: var(--surface-hover) !important;
            color: var(--text-color) !important;
            border-radius: var(--border-radius-sm) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            min-height: 44px;
        }
        .choices__inner {
            background: transparent !important;
            color: var(--text-color) !important;
            border: none !important;
            border-radius: var(--border-radius-sm) !important;
            min-height: 44px;
            padding: 6px 10px 2px 10px;
        }
        .choices__list--multiple .choices__item {
            background: var(--accent-color) !important;
            color: #fff !important;
            border-radius: 8px !important;
            border: none !important;
            margin: 2px 4px 2px 0;
            padding: 4px 10px;
            font-size: 0.95em;
        }
        .choices__list--dropdown, .choices__list[aria-expanded] {
            background: var(--surface-color) !important;
            color: var(--text-color) !important;
            border-radius: var(--border-radius-sm) !important;
            border: 1px solid var(--accent-color) !important;
        }
        .choices__item--selectable.is-highlighted {
            background: var(--accent-color) !important;
            color: #fff !important;
        }
        .choices__input {
            background: transparent !important;
            color: var(--text-color) !important;
        }
        .choices__button {
            color: #fff !important;
            background: transparent !important;
            border: none !important;
            border-radius: 50%;
            margin-left: 4px;
            font-size: 1.2em !important;
            opacity: 0.85;
            box-shadow: none !important;
            cursor: pointer;
            line-height: 1;
            padding: 0 4px;
            display: flex;
            align-items: center;
            position: relative;
        }
        .choices__button::after {
            content: '\00d7';
            color: #fff;
            font-size: 1.2em;
            font-weight: bold;
            display: inline-block;
            vertical-align: middle;
        }
        .choices__button > span,
        .choices__button > svg {
            display: none !important;
        }
        .choices__button:hover::after,
        .choices__button:focus::after {
            color: var(--error-color) !important;
        }
        .choices[data-type*=select-one] .choices__inner {
            padding-bottom: 0;
        }
        .choices[data-type*=select-multiple] .choices__inner {
            min-height: 44px;
        }
        .choices__placeholder {
            color: var(--text-muted) !important;
            opacity: 0.8;
        }
        /* ===== VARIABLES CSS ===== */
:root {
    --bg-color: #1a1c2e;
    --surface-color: #2a2d42;
    --surface-hover: #3a3d52;
    --accent-color: #00C851;
    --accent-hover: #00A043;
    --text-color: #e0e0e0;
    --text-muted: #B0B0B0;
    --error-color: #ff4d4d;
    --error-hover: #e83a3a;
    --sidebar-width: 250px;
    --border-radius: 12px;
    --border-radius-sm: 8px;
    --transition: all 0.3s ease;
}

/* ===== BASE STYLES ===== */
body {
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: 'Poppins', sans-serif;
    font-size: 16px;
}

/* ===== LAYOUT ===== */
.dashboard-container {
    display: flex;
}

.main-content {
    margin-left: var(--sidebar-width);
    width: calc(100% - var(--sidebar-width));
    padding: 40px;
}

/* ===== SIDEBAR ===== */
.sidebar {
    width: var(--sidebar-width);
    height: 100vh;
    background-color: var(--surface-color);
    position: fixed;
    top: 0;
    left: 0;
    padding: 20px;
    display: flex;
    flex-direction: column;
}

.sidebar-header {
    text-align: center;
    margin-bottom: 30px;
}

.sidebar-header h2 {
    color: var(--accent-color);
    font-weight: 700;
    margin-bottom: 0;
}

.sidebar .nav-link {
    color: var(--text-muted);
    padding: 15px;
    margin-bottom: 10px;
    border-radius: var(--border-radius-sm);
    transition: var(--transition);
    display: flex;
    align-items: center;
    text-decoration: none;
}

.sidebar .nav-link i {
    margin-right: 15px;
    font-size: 1.2rem;
}

.sidebar .nav-link:hover,
.sidebar .nav-link.active {
    background-color: var(--accent-color);
    color: #fff;
}

/* ===== USER PROFILE ===== */
.user-profile {
    margin-top: auto;
    padding: 15px;
    background-color: rgba(0, 0, 0, 0.2);
    border-radius: 10px;
}

.user-profile .user-details {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 15px;
}

.user-profile .user-avatar {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    border: 2px solid var(--accent-color);
}

.user-profile .user-name {
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 1.1rem;
}

.user-profile .btn {
    width: 100%;
    font-weight: 600;
    border-radius: var(--border-radius-sm);
    transition: var(--transition);
}

.user-profile .btn-login {
    background-color: var(--accent-color);
    border-color: var(--accent-color);
    color: #fff;
}

.user-profile .btn-login:hover {
    background-color: var(--accent-hover);
    border-color: var(--accent-hover);
}

.user-profile .btn-logout {
    background-color: var(--error-color);
    border-color: var(--error-color);
    color: #fff;
}

.user-profile .btn-logout:hover {
    background-color: var(--error-hover);
    border-color: var(--error-hover);
}

/* ===== CARDS ===== */
.stat-card,
.guild-card,
.card {
    background-color: var(--surface-color) !important;
    border-radius: var(--border-radius);
    padding: 25px;
    margin-bottom: 20px;
    border: 1px solid transparent;
    transition: var(--transition);
    color: var(--text-color);
}

.stat-card:hover,
.guild-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent-color);
}

.stat-card .card-title {
    color: var(--text-muted);
    font-size: 1rem;
}

.stat-card .card-text {
    color: #fff;
    font-size: 2.5rem;
    font-weight: 700;
}

.guild-card {
    text-align: center;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.guild-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    margin: 0 auto 15px auto;
    display: block;
    object-fit: cover;
}

.guild-icon-default {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    margin: 0 auto 15px auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--accent-color);
    color: #fff;
    font-size: 2.5rem;
    font-weight: 700;
}

.guild-icon-large {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
}

.guild-icon-large.guild-icon-default {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--accent-color);
    color: #fff;
    font-size: 2rem;
    font-weight: 700;
}

.guild-name {
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 20px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.guild-card .btn-primary {
    background-color: var(--accent-color);
    border-color: var(--accent-color);
    font-weight: 600;
}

.guild-card .btn-primary:hover {
    background-color: var(--accent-hover);
    border-color: var(--accent-hover);
}

/* ===== FORM INPUTS ===== */
.form-control,
.form-select {
    background-color: var(--surface-hover) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    color: var(--text-color) !important;
    border-radius: var(--border-radius-sm);
    transition: var(--transition);
}

.form-control:focus,
.form-select:focus {
    background-color: var(--surface-hover) !important;
    border-color: var(--accent-color) !important;
    box-shadow: 0 0 0 0.2rem rgba(0, 200, 81, 0.25) !important;
    color: var(--text-color) !important;
}

.form-control::placeholder {
    color: var(--text-muted) !important;
    opacity: 0.8;
}

/* Form labels */
.form-label {
    color: var(--text-color);
    font-weight: 500;
}

/* Input group styling */
.input-group-text {
    background-color: var(--surface-hover) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    color: var(--text-color) !important;
}

/* Select options styling */
.form-select option {
    background-color: var(--surface-color);
    color: var(--text-color);
}

/* ===== TABLES ===== */
.table {
    background-color: var(--surface-color) !important;
    color: var(--text-color);
    border-radius: var(--border-radius);
    overflow: hidden;
    margin-bottom: 0;
}

.table thead {
    background-color: var(--surface-color) !important;
}

.table th,
.table td {
    border: none;
    padding: 15px;
    vertical-align: middle;
    background-color: var(--surface-color) !important;
    color: var(--text-color) !important;
}

.table-hover tbody tr:hover td {
    background-color: var(--surface-hover) !important;
    color: #fff !important;
}

/* ===== TEXT UTILITIES ===== */
.main-content .text-muted {
    color: var(--text-color) !important;
}

.main-content .stat-card a {
    color: var(--text-color) !important;
}

/* ===== RESPONSIVE DESIGN ===== */
@media (max-width: 991.98px) {
    .sidebar {
        left: -100%;
        transition: left 0.3s ease;
        z-index: 1030;
        box-shadow: 0 0 15px rgba(0, 0, 0, 0.5);
    }

    .sidebar.show {
        left: 0;
    }

    .main-content {
        margin-left: 0;
        width: 100%;
        padding-top: 60px;
    }

    .sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
    }

    .mobile-sidebar-toggle {
        background-color: var(--surface-color);
        border: 1px solid var(--accent-color);
        border-radius: var(--border-radius-sm);
        padding: 8px 12px;
        position: fixed;
        top: 15px;
        left: 15px;
        z-index: 1020;
        color: var(--text-color);
    }
}
    </style>
</head>

<body>
    <div class="dashboard-container">